{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DevDock",
  "version": "0.1.0",
  "identifier": "com.devdock.app",
  "build": {
    "frontendDist": "../public"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "DevDock",
        "label": "main",
        "width": 520,
        "height": 680,
        "minWidth": 420,
        "minHeight": 500,
        "resizable": true,
        "decorations": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
